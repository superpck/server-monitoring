# ── API Gateway ───────────────────────────────────────────────────────────────
PORT=4000

# ── Admin Login ───────────────────────────────────────────────────────────────
# POST /auth/login  body: { username: "superadmin", password: "<SUPERADMIN_PASSWORD>" }
SUPERADMIN_PASSWORD=change-this-to-a-strong-password

# Secret used to sign JWT tokens (min 32 chars recommended)
JWT_SECRET=change-this-to-a-random-jwt-secret-min-32-chars

# Token lifetime — examples: 8h, 1d, 7d
JWT_EXPIRES_IN=8h

# ── Machine-to-machine static key (optional) ─────────────────────────────────
# Authorization: Bearer <UI_API_KEY>  (fallback when no JWT login is used)
UI_API_KEY=change-this-to-a-strong-random-secret

# ── Agents ────────────────────────────────────────────────────────────────────
# JSON array of agent configurations.
# Each entry must include:
#   id         – unique identifier used in proxy URL  /proxy/:id/*
#   name       – human-readable name
#   group      – logical group name
#   url        – agent base URL (no trailing slash)
#   server_key – must match SERVER_KEY in agent's .env
#
# Example:
# AGENTS='[
#   {"id":"web-151","name":"Web","group":"nRefer@MOPH","url":"https://nrefer.moph.go.th/svr-mng-151","server_key":"agent-secret-key-32to128chars"},
#   {"id":"api-152","name":"API-1","group":"nRefer@MOPH","url":"https://nrefer.moph.go.th/svr-mng-152","server_key":"agent-secret-key-32to128chars"}
# ]'
AGENTS='[]'
