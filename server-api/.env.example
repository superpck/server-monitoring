PORT=3003

# ── Security ──────────────────────────────────────────────────────────────────
# Unique name for this agent — clients must send X-Server-Name header matching this value
SERVER_NAME=agent-server-01

# Secret key for this agent — clients must send X-Server-Key header matching this value
# Recommended: 32–128 random characters
SERVER_KEY=agent-secret-key-32to128chars

# Optional: restrict access to specific IP ranges (comma-separated CIDR notation)
# Leave empty to allow all IPs (localhost is always allowed)
# Example: ALLOWED_IP_RANGES=192.168.0.1/24,10.0.0.0/8
ALLOWED_IP_RANGES=

# ── Database Monitoring ───────────────────────────────────────────────────────
# Set to 'true' to enable the /database/* endpoints
DB_MONITOR_ENABLED=false

# Array of DB instances (JSON). Each object supports:
#   id       – unique label shown in responses
#   vendor   – mysql | mariadb | percona | pgsql | mssql
#   enabled  – set to false to skip this instance without removing it
#   host, port, user, password, database
DB_INSTANCES='[{"id":"mysql-primary","vendor":"mysql","enabled":true,"host":"127.0.0.1","port":3306,"user":"monitor","password":"secret","database":"app"},{"id":"pg-analytics","vendor":"pgsql","enabled":false,"host":"127.0.0.1","port":5432,"user":"monitor","password":"secret","database":"analytics"},{"id":"mssql-erp","vendor":"mssql","enabled":false,"host":"127.0.0.1","port":1433,"user":"monitor","password":"secret","database":"erp"}]'

# ── Nginx Log Monitoring ──────────────────────────────────────────────────────
# Set to 'true' to enable GET /nginx/log and GET /nginx/log/stream
NGINX_LOG_ENABLED=false

# URL used to HTTP-check nginx (useful when nginx runs in a separate container)
NGINX_CHECK_URL=http://localhost

# Override default log file paths (optional)
NGINX_ACCESS_LOG=/var/log/nginx/access.log
NGINX_ERROR_LOG=/var/log/nginx/error.log

# ── System Overview ───────────────────────────────────────────────────────────
# Set to 'true' to enable GET /system/overview
# Returns: uname, who, w, last logins, listening ports, running/failed services,
#          crontab, DNS, timezone, hardware info
# Supported platforms: Linux (RHEL/Debian), macOS, Windows
SYSTEM_OVERVIEW_ENABLED=false

# ── Secure Log Monitoring ─────────────────────────────────────────────────────
# Set to 'true' to enable GET /secure/sources and GET /secure/log
# RHEL/CentOS/Rocky : /var/log/secure, /var/log/messages, /var/log/audit/audit.log
# Debian/Ubuntu     : /var/log/auth.log, /var/log/syslog, /var/log/kern.log
# macOS             : log show (Unified Log, security subsystem)
# Windows           : wevtutil Security / System event log
SECURE_LOG_ENABLED=false

# Maximum lines returned per request (1–500, default 100)
SECURE_LOG_LINES=100
